[
 {
  "doctype": "Custom Field",
  "dt": "Item",
  "fieldname": "lim_section",
  "fieldtype": "Section Break",
  "label": "Inventory Monitor",
  "insert_after": "reorder_levels",
  "collapsible": 1,
  "module": "Lexington Inventory",
  "name": "Item-lim_section"
 },
 {
  "doctype": "Custom Field",
  "dt": "Item",
  "fieldname": "lim_reorder_level",
  "fieldtype": "Float",
  "label": "Reorder Level (LIM)",
  "insert_after": "lim_section",
  "description": "Alert when stock falls below this level. Overrides native reorder table.",
  "module": "Lexington Inventory",
  "name": "Item-lim_reorder_level"
 },
 {
  "doctype": "Custom Field",
  "dt": "Item",
  "fieldname": "lim_reorder_qty",
  "fieldtype": "Float",
  "label": "Reorder Qty (LIM)",
  "insert_after": "lim_reorder_level",
  "description": "Qty to order when restocking. Used for auto-PO creation.",
  "module": "Lexington Inventory",
  "name": "Item-lim_reorder_qty"
 },
 {
  "doctype": "Custom Field",
  "dt": "Item",
  "fieldname": "lim_preferred_supplier",
  "fieldtype": "Link",
  "label": "Preferred Supplier (LIM)",
  "options": "Supplier",
  "insert_after": "lim_reorder_qty",
  "module": "Lexington Inventory",
  "name": "Item-lim_preferred_supplier"
 },
 {
  "doctype": "Custom Field",
  "dt": "Item",
  "fieldname": "lim_cycle_count_frequency",
  "fieldtype": "Select",
  "label": "Cycle Count Frequency",
  "options": "\nWeekly\nBi-Weekly\nMonthly\nQuarterly\nAnnually",
  "insert_after": "lim_preferred_supplier",
  "module": "Lexington Inventory",
  "name": "Item-lim_cycle_count_frequency"
 },
 {
  "doctype": "Custom Field",
  "dt": "Item",
  "fieldname": "lim_last_count_date",
  "fieldtype": "Date",
  "label": "Last Count Date",
  "insert_after": "lim_cycle_count_frequency",
  "read_only": 1,
  "module": "Lexington Inventory",
  "name": "Item-lim_last_count_date"
 },
 {
  "doctype": "Custom Field",
  "dt": "Purchase Order",
  "fieldname": "lim_auto_generated",
  "fieldtype": "Check",
  "label": "Auto-Generated by LIM",
  "insert_after": "amended_from",
  "read_only": 1,
  "module": "Lexington Inventory",
  "name": "Purchase Order-lim_auto_generated"
 },
 {
  "doctype": "Custom Field",
  "dt": "Purchase Order",
  "fieldname": "lim_alert_ref",
  "fieldtype": "Link",
  "label": "Inventory Alert",
  "options": "Inventory Alert",
  "insert_after": "lim_auto_generated",
  "read_only": 1,
  "module": "Lexington Inventory",
  "name": "Purchase Order-lim_alert_ref"
 },
 {
  "doctype": "Custom Field",
  "dt": "Stock Reconciliation",
  "fieldname": "inventory_count_ref",
  "fieldtype": "Link",
  "label": "Inventory Count",
  "options": "Inventory Count",
  "insert_after": "amended_from",
  "read_only": 1,
  "module": "Lexington Inventory",
  "name": "Stock Reconciliation-inventory_count_ref"
 }
]
